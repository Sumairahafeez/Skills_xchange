<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.SkillsExchange" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorTertiary">@color/color_accent_light</item>
        <item name="colorSurface">@color/color_bg_surface</item>
        <item name="android:colorBackground">@color/color_bg_page</item>
        <item name="colorOnBackground">@color/color_text_primary</item>
        <item name="colorOnSurface">@color/color_text_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorPrimaryContainer">@color/color_bg_input</item>
        <item name="colorOnPrimaryContainer">@color/color_primary_dark</item>
        <item name="colorSurfaceVariant">@color/color_bg_input</item>
        <item name="colorOnSurfaceVariant">@color/color_secondary</item>
        <item name="android:windowBackground">@color/color_bg_page</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:textColorPrimary">@color/color_text_primary</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>
        <item name="elevationOverlayEnabled">false</item>
    </style>

    <style name="Theme.SkillsExchange" parent="Base.Theme.SkillsExchange" />

    <style name="SkillsExchange.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/white</item>
        <item name="titleTextColor">@color/color_text_primary</item>
        <item name="navigationIconTint">@color/color_text_primary</item>
    </style>

    <style name="SkillsExchange.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/color_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="SkillsExchange.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/color_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="SkillsExchange.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/color_primary</item>
        <item name="android:textColor">@color/color_primary</item>
        <item name="cornerRadius">24dp</item>
    </style>
</resources>