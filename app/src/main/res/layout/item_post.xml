<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Header: avatar + name + title + time -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPostUserAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/color_primary_light"
                app:strokeWidth="1.5dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/ivPostUserAvatar"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPostUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textColor="@color/color_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPostUserTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expertise"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="1dp" />

                <TextView
                    android:id="@+id/tvPostTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2h ago · 🌐"
                    android:textColor="@color/color_text_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

        </RelativeLayout>

        <!-- Post content -->
        <TextView
            android:id="@+id/tvPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp"
            android:lineSpacingExtra="5dp"
            android:text="This is a skill-related post content..."
            android:textColor="@color/color_text_primary"
            android:textSize="15sp" />

        <!-- Media container with image view -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/postMediaContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/color_bg_input"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/ivPostImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:maxHeight="300dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp" />

        <!-- Action Bar: Like | Ask | Comments -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLike"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="Like"
                android:textSize="13.5sp"
                android:textColor="@color/color_text_secondary"
                app:icon="@android:drawable/btn_star_big_off"
                app:iconTint="@color/color_text_secondary"
                app:iconSize="20dp"
                app:rippleColor="@color/color_primary_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAskQuestion"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="Ask"
                android:textSize="13.5sp"
                android:textColor="@color/color_text_secondary"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="@color/color_text_secondary"
                app:iconSize="20dp"
                app:rippleColor="@color/color_primary_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnComments"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="Comments"
                android:textSize="13.5sp"
                android:textColor="@color/color_text_secondary"
                app:icon="@android:drawable/sym_action_chat"
                app:iconTint="@color/color_text_secondary"
                app:iconSize="20dp"
                app:rippleColor="@color/color_primary_light" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
