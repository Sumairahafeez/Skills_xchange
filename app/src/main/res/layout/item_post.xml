<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeColor="#F0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header row: avatar + name + time -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Avatar circle with initials feel -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPostUserAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:padding="2dp"
                android:background="@drawable/bg_avatar_ring"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/color_primary_light"
                app:strokeWidth="1.5dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="14dp"
                android:layout_toEndOf="@id/ivPostUserAvatar"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPostUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvPostUserTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expertise"
                    android:textColor="@color/color_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPostTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="2h ago"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />
        </RelativeLayout>

        <!-- Post content -->
        <TextView
            android:id="@+id/tvPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp"
            android:text="This is a skill-related post content..."
            android:textColor="#2D2D2D"
            android:textSize="14sp"
            android:fontFamily="sans-serif" />

        <!-- Media container (video) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/postMediaContainer"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFF0F0">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/color_primary" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="#F5EDED" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Inspiring"
                android:textSize="13sp"
                android:textColor="@color/color_secondary"
                app:icon="@android:drawable/btn_star_big_off"
                app:iconTint="@color/color_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAskQuestion"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1.2"
                android:layout_height="40dp"
                android:text="Ask Question"
                android:textSize="13sp"
                android:textColor="@color/color_primary"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="@color/color_primary" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>