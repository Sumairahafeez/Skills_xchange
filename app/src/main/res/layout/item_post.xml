<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_card_stroke"
    app:strokeWidth="0.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Header: avatar + name + title + time -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPostUserAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/color_divider"
                app:strokeWidth="1dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/ivPostUserAvatar"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPostUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textColor="@color/color_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPostUserTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expertise"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12.5sp"
                    android:layout_marginTop="1dp" />

                <TextView
                    android:id="@+id/tvPostTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2h ago · 🌐"
                    android:textColor="@color/color_text_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

        </RelativeLayout>

        <!-- Post content -->
        <TextView
            android:id="@+id/tvPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp"
            android:lineSpacingExtra="4dp"
            android:text="This is a skill-related post content..."
            android:textColor="@color/color_text_primary"
            android:textSize="14.5sp" />

        <!-- Media container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/postMediaContainer"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/color_bg_input">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_play"
                    android:background="@color/white"
                    android:padding="12dp"
                    app:tint="@color/color_primary" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Bar: Like | Ask | Share -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLike"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="Like"
                android:textSize="13.5sp"
                android:textColor="@color/color_text_secondary"
                app:icon="@android:drawable/btn_star_big_off"
                app:iconTint="@color/color_text_secondary"
                app:iconSize="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAskQuestion"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="Ask"
                android:textSize="13.5sp"
                android:textColor="@color/color_text_secondary"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="@color/color_text_secondary"
                app:iconSize="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShare"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="Share"
                android:textSize="13.5sp"
                android:textColor="@color/color_text_secondary"
                app:icon="@android:drawable/ic_menu_share"
                app:iconTint="@color/color_text_secondary"
                app:iconSize="20dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>