<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chatBubbleContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <!-- Regular Text Bubble -->
    <TextView
        android:id="@+id/tvChatBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="260dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.2" />

    <!-- Shared Post Card (Hidden by default) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSharedPost"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/color_divider"
        android:layout_marginTop="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvSharedPostAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/color_primary"
                android:text="Post Author" />

            <TextView
                android:id="@+id/tvSharedPostContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="13sp"
                android:maxLines="4"
                android:ellipsize="end"
                android:textColor="@color/color_text_primary"
                android:text="Post content goes here..." />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="11sp"
                android:textColor="@color/color_primary"
                android:text="View Post →" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>